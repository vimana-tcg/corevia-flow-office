# ────────────────────────────────────────────────────────────────────────────
# Corevia Flow Office — ваши ключи. Скопируйте этот файл в `.env` и заполните.
# `.env` НИКОГДА не попадёт в git (он в .gitignore). Не вставляйте ключи в код.
# Заполнять не всё сразу — только то, чем пользуетесь. Мастер /setup поможет.
# ────────────────────────────────────────────────────────────────────────────

# ── Мозг (LLM) — обязателен хотя бы один ──
ANTHROPIC_API_KEY=          # console.anthropic.com  (Claude — рекомендуем)
OPENAI_API_KEY=             # platform.openai.com    (GPT, Whisper, картинки)

# ── Картинки / медиа ──
REPLICATE_API_TOKEN=        # replicate.com/account/api-tokens  (Ideogram/Flux/rembg)
GEMINI_API_KEY=             # aistudio.google.com/apikey  (nano-banana, нужен биллинг для картинок)
PEXELS_API_KEY=             # pexels.com/api  (бесплатные стоковые фото)
ELEVENLABS_API_KEY=         # elevenlabs.io  (озвучка/клон голоса) — опц.

# ── Дизайн ──
# Canva подключается как MCP (не ключом) — см. docs/SETUP.md

# ── Соцсети / реклама (для публикации и перформанса) ──
META_ACCESS_TOKEN=          # developers.facebook.com  (FB/IG Graph API, Ads)
META_AD_ACCOUNT_ID=         # act_XXXXXXXXX
YOUTUBE_CLIENT_ID=          # console.cloud.google.com  (YouTube Data API)
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
TIKTOK_CLIENT_KEY=          # developers.tiktok.com  (Content Posting API, нужен аудит)
TIKTOK_CLIENT_SECRET=

# ── Аналитика (опц.) ──
GA4_PROPERTY_ID=
UMAMI_API_URL=

# ── Прочее ──
# Каждый сервис подключается по желанию. Запустите `/doctor`, чтобы увидеть,
# что уже подключено и чего не хватает под вашу задачу.
