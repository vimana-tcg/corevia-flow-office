{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MrBeast-style editing script (cut plan)",
  "description": "–°—В—А—Г–Ї—В—Г—А–∞ —А–Њ–ї–Є–Ї–∞: —Б—Ж–µ–љ—Л hookвЖТstakesвЖТproofвЖТloopвЖТcta —Б–Њ —Б–ї–Њ–µ–Љ —Г–і–µ—А–ґ–∞–љ–Є—П. –°–Ї–∞—А–Љ–ї–Є–≤–∞–µ—В—Б—П –і–≤–Є–ґ–Ї—Г —А–µ–љ–і–µ—А–∞ (montage.py).",
  "type": "object",
  "required": ["target_duration", "scenes"],
  "properties": {
    "target_duration": {"type": "number", "description": "–¶–µ–ї–µ–≤–∞—П –і–ї–Є–љ–∞ —А–Њ–ї–Є–Ї–∞, —Б–µ–Ї"},
    "platform": {"type": "string", "enum": ["reels", "tiktok", "shorts", "youtube_long"]},
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["idx", "type", "text", "duration", "visual"],
        "properties": {
          "idx": {"type": "integer"},
          "type": {"type": "string", "enum": ["hook", "stakes", "proof", "explanation", "rehook", "cta"]},
          "text": {"type": "string", "description": "–†–µ–њ–ї–Є–Ї–∞ –і–Є–Ї—Ж–Є–Є (verbatim –Є–Ј —В—А–∞–љ—Б–Ї—А–Є–њ—В–∞)"},
          "start": {"type": "number"},
          "end": {"type": "number"},
          "duration": {"type": "number", "description": "–Ф–ї–Є—В–µ–ї—М–љ–Њ—Б—В—М —Б—Ж–µ–љ—Л, —Б–µ–Ї (—Ж–µ–ї—М 1.5-3.0)"},
          "visual": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": {"type": "string", "enum": ["live", "freeze", "broll", "avatar"]},
              "source_ts": {"type": ["number", "null"], "description": "–Ґ–∞–є–Љ–Ї–Њ–і –≤ –Є—Б—Е–Њ–і–љ–Є–Ї–µ –і–ї—П live/freeze"},
              "broll_query": {"type": ["string", "null"], "description": "–Я–Њ–Є—Б–Ї–Њ–≤—Л–є –Ј–∞–њ—А–Њ—Б –њ–Њ–і —З—Г–ґ–Њ–є –Ї–∞–і—А (Pexels/Pixabay)"}
            }
          },
          "zoom": {"type": "string", "enum": ["none", "punch", "kenburns"], "default": "none"},
          "sfx": {"type": "string", "enum": ["none", "whoosh", "ding", "boom", "silence"], "default": "none"},
          "caption_focus": {"type": ["string", "null"], "description": "–°–ї–Њ–≤–Њ-–∞–Ї—Ж–µ–љ—В, –њ–Њ–і—Б–≤–µ—В–Є—В—М —Ж–≤–µ—В–Њ–Љ"}
        }
      }
    }
  }
}
